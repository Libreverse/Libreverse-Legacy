{
    // Make the VS Code Pull button use rebase instead of merge
    "git.pullRebase": true,
    // Prune on fetch so the remote view is tidy
    "git.pruneOnFetch": true,
    // Do not force fast-forward only in the UI pull; rebase will handle divergence
    "git.fastForwardOnly": false,
    // Avoid passing --tags with Pull button; tag fetch can be done by fetch
    "git.fetchTags": false,
    // Auto-fetch periodically to keep things fresh
    "git.autofetch": true,
    "sarif-viewer.connectToGithubCodeScanning": "on",
    "snyk.advanced.autoSelectOrganization": true,
    "snyk.advanced.organization": "eb5b73e8-84e3-474f-915c-fd9f91fce1c3"
}
